# Application
NODE_ENV=development
PORT=3010
APP_NAME="Pharmacy Sys API"
APP_URL=http://localhost:3010

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@127.0.0.1:5432/pharmacy_sys?schema=public

# JWT (use long random strings in production — minimum 32 characters)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Security
BCRYPT_ROUNDS=10
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=info

# Market defaults (Egypt primary, Saudi secondary)
DEFAULT_CURRENCY=EGP
DEFAULT_TIMEZONE=Africa/Cairo
DEFAULT_LOCALE=ar
SUPPORTED_CURRENCIES=EGP,SAR
SUPPORTED_TIMEZONES=Africa/Cairo,Asia/Riyadh
SUPPORTED_LOCALES=ar,en

# Base seed — administrator account (created by npm run db:seed)
SEED_ADMIN_EMAIL=admin@pharmacy.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_ADMIN_NAME=System Admin
SEED_SHOP_NAME=Default Pharmacy

# QA / demo seed — staff accounts (created by npm run db:qa-seed)
QA_PASSWORD=Pharmacy@123

# SMTP (optional — invoice email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pharmacy.local
SMTP_SECURE=false

# Demo mode flag (optional)
APP_DEMO=false
